# Copia este archivo a .env y completa los valores

# Base de datos
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sgg
SPRING_DATASOURCE_USERNAME=sgg_admin
SPRING_DATASOURCE_PASSWORD=sgg_local_pass

# Supabase (completar cuando tengas el proyecto creado)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_JWKS_URI=https://xxxxxxxxxxxx.supabase.co/auth/v1/jwks
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase

# CORS
APP_CORS_WEB_ORIGIN=http://localhost:3000
APP_CORS_ADDITIONAL_ORIGINS=http://localhost:8081,http://localhost:19006

# Modo desarrollo (true = sin autenticación JWT, solo para desarrollo local)
APP_DEV_MODE=true
